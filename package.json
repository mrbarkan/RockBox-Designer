{
  "name": "rockbox-designer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "registry:generate": "node scripts/generate-rockbox-tag-registry.mjs",
    "registry:verify": "node scripts/verify-rockbox-tag-registry.mjs",
    "validate": "npm run registry:verify && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "jszip": "^3.10.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.9.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.10"
  }
}
