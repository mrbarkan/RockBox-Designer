{
  "name": "rockbox-designer",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:official": "tsx scripts/official/run-official-validation.ts",
    "test:phase2-official": "tsx scripts/phase2/run-phase2-official-validation.ts",
    "test:phase3-official": "tsx scripts/phase3/run-phase3-official-validation.ts",
    "test:phase2-real": "tsx scripts/phase2/run-real-theme-edit.ts",
    "test:phase3-real": "tsx scripts/phase3/run-real-theme-screens.ts",
    "test:phase3-font": "tsx scripts/fonts/run-native-font-validation.ts",
    "test:themes": "npm run themes:fixtures:verify && tsx scripts/themes/run-theme-compatibility.ts",
    "test:visual": "vitest run tests/rendering/pixelRenderer.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "device:verify": "node scripts/verify-rockbox-device-profiles.mjs",
    "official:report:verify": "node scripts/verify-official-parser-report.mjs",
    "phase2:official:report:verify": "node scripts/verify-phase2-official-report.mjs",
    "phase3:official:report:verify": "node scripts/verify-phase3-official-report.mjs",
    "phase2:real:report:verify": "node scripts/verify-phase2-real-theme-report.mjs",
    "phase3:real:report:verify": "node scripts/verify-phase3-real-theme-report.mjs",
    "phase3:font:report:verify": "node scripts/verify-phase3-font-report.mjs",
    "font:convert": "tsx scripts/fonts/convert-font.ts",
    "theme:report:verify": "node scripts/verify-theme-compatibility-report.mjs",
    "themes:fixtures:generate": "node scripts/themes/generate-public-theme-fixtures.mjs",
    "themes:fixtures:verify": "node scripts/themes/generate-public-theme-fixtures.mjs --check",
    "themes:prepare-private": "tsx scripts/themes/prepare-private-themes.ts",
    "visual:golden:generate": "tsx scripts/visual/generate-phase2-golden.ts && tsx scripts/visual/generate-phase3-goldens.ts",
    "registry:generate": "node scripts/generate-rockbox-tag-registry.mjs",
    "registry:verify": "node scripts/verify-rockbox-tag-registry.mjs",
    "validate": "npm run registry:verify && npm run device:verify && npm run official:report:verify && npm run phase2:official:report:verify && npm run phase2:real:report:verify && npm run phase3:official:report:verify && npm run phase3:real:report:verify && npm run phase3:font:report:verify && npm run theme:report:verify && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.38.0",
    "jszip": "^3.10.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-check": "^4.9.0",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.10"
  }
}
